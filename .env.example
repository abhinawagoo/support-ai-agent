# Copy to .env and fill in values.
# Local UI: streamlit run streamlit_app.py
#
# Railway: set the same names under Project → Variables (do not commit .env).

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=
EXA_API_KEY=

# Optional defaults (can also be set in the Streamlit sidebar)
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-6

# Default provider for the UI: openai | anthropic
LLM_PROVIDER=openai

# Dottle monitoring (optional). If DOTTLE_API_KEY is unset, nothing is sent.
# DOTTLE_URL=https://dottle-production.up.railway.app/api/v1
# DOTTLE_API_KEY=dtl_live_...
# DOTTLE_AGENT_NAME=support-ai-agent
# DOTTLE_USER_ID=
# DOTTLE_USER_EMAIL=
# DOTTLE_AGENT_VERSION=
# DOTTLE_TAGS=production,railway
# DOTTLE_REDACT_PII=true

# Set only for pytest / scripts/run_dottle_scenarios.py (forces synchronous ingest posts).
# DOTTLE_TEST_SYNC=1

# --- Telegram + Ops automation (terminal bot) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# EXA_API_KEY=
#
# # Supabase storage (table defaults to agent_reports)
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_TABLE=agent_reports
#
# # Google Docs/Sheets (service account JSON file path on disk)
# GOOGLE_SERVICE_ACCOUNT_JSON=/absolute/path/service-account.json
# GOOGLE_DOC_ID=
# GOOGLE_SHEET_ID=
# GOOGLE_SHEET_NAME=Reports
#
# # Local Excel output (xlsx)
# EXCEL_FILE_PATH=reports.xlsx
#
# # Optional Slack notification
# SLACK_WEBHOOK_URL=
